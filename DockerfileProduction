FROM snbh-server-base:7.2-node

RUN docker-php-ext-enable redis

ENV NR_INSTALL_SILENT=1
ENV NR_INSTALL_KEY=e9479f1a8574667a610b4cb062a9135144628e4f
ENV NEW_RELIC_APP_NAME="area_restrita"

COPY . .

RUN apt-get install -y zlib1g-dev libicu-dev g++ \
    && docker-php-ext-configure intl \
    && docker-php-ext-install intl

ARG SESSION_PHP_SAVE_HANDLER
ARG SESSION_SAVE_PATH

RUN echo "session.cookie_domain=seminovos.com.br\n\
session.save_handler=$SESSION_PHP_SAVE_HANDLER\n\
session.save_path=\"$SESSION_SAVE_PATH\"" > /usr/local/etc/php/conf.d/snbh-session.ini

RUN echo "newrelic.appname=area_restrita" > /usr/local/etc/php/conf.d/snbh-newrelic.ini

RUN echo "memory_limit=256M" > /usr/local/etc/php/conf.d/snbh-memory.ini
RUN echo "max_input_vars=10000" > /usr/local/etc/php/conf.d/snbh-input_vars.ini

RUN set -eux; \
    # Reseta a pasta data e cria a versão do sistema \
    rm -rf data; \
    git checkout data; \
    chmod -R 777 data; \
    echo -n "$(git describe)" > version; \
    chmod 777 version; \
    #
    # Instala dependencias do compsoer e apaga o cache
    composer install \
        --no-dev \
        --no-interaction \
        --optimize-autoloader \
        --apcu-autoloader \
        --no-progress; \
    rm -rf ~/.composer/cache/*; \
    #
    # Instala os pacotes de front e gera os assets 
    npm install; \
    npm run compile-icons; \
    npm run prod



RUN apt-get --allow-releaseinfo-change update && \
    apt-get -yq install wget && \
    wget -O - https://download.newrelic.com/548C16BF.gpg | apt-key add - && \
    echo "deb http://apt.newrelic.com/debian/ newrelic non-free" > /etc/apt/sources.list.d/newrelic.list && \
    apt-get update && \
    apt-get -yq install newrelic-php5 && \
    newrelic-install install

RUN apt-get install htop -y

RUN ln -sf /dev/stdout /var/log/nginx/access.log && ln -sf /dev/stderr /var/log/nginx/error.log
COPY server/nginx/sites-enabled/default /etc/nginx/sites-enabled/default
COPY server/php-fpm.d/www.conf /usr/local/etc/php-fpm.d/www.conf
