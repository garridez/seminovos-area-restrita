FROM snbh-server-base:7.2-node

RUN yes '' | pecl install -o -f redis \
    &&  rm -rf /tmp/pear \
    &&  docker-php-ext-enable redis

COPY . .

ARG SESSION_PHP_SAVE_HANDLER
ARG SESSION_SAVE_PATH

RUN echo "session.save_handler=$SESSION_PHP_SAVE_HANDLER\n\
session.save_path=\"$SESSION_SAVE_PATH\"" > /usr/local/etc/php/conf.d/snbh-session-redis.ini

RUN set -eux; \
    # Reseta a pasta data e cria a versão do sistema \
    rm -rf data; \
    git checkout data; \
    chmod -R 777 data; \
    echo -n "$(git describe)" > version; \
    #
    # Instala dependencias do compsoer e apaga o cache
    composer install \
        --no-dev \
        --no-interaction \
        --optimize-autoloader \
        --apcu-autoloader \
        --no-progress; \
    rm -rf ~/.composer/cache/*; \
    #
    # Instala os pacotes de front e gera os assets 
    npm install; \
    npm run prod; \
    #
    # Limpa os dados temporários de desinstala os pacotes
    npm cache clean --force; \
    apt-get purge gnupg nodejs libpng-dev python3 -y; \
    apt-get clean; \
    apt-get autoremove -y; \
    rm -rf node_modules resources composer.phar; \
    rm -rf /var/lib/apt/lists/*; \
    mkdir -p /var/cache/apt/archives

RUN ln -sf /dev/stdout /var/log/nginx/access.log && ln -sf /dev/stderr /var/log/nginx/error.log
COPY server/nginx/sites-enabled/default /etc/nginx/sites-enabled/default
COPY server/php-fpm.d/www.conf /usr/local/etc/php-fpm.d/www.conf
