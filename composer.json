{
    "name": "snbh/area-restrita",
    "description": "Skeleton Application for Zend Framework zend-mvc applications",
    "type": "project",
    "license": "BSD-3-Clause",
    "keywords": [
        "framework",
        "mvc",
        "zf"
    ],
    "homepage": "http://framework.zend.com/",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^5.6 || ^7.0",
        "http-interop/http-middleware": "0.4.1",
        "neilime/zf2-twb-bundle": "^3.2",
        "snbh/api-client-module": "dev-master",
        "zendframework/zend-cache": "^2.7.1",
        "zendframework/zend-component-installer": "^1.0 || ^0.7 || ^1.0.0-dev@dev",
        "zendframework/zend-log": "^2.9",
        "zendframework/zend-mvc": "^3.0.1",
        "zendframework/zend-mvc-form": "^1.0",
        "zendframework/zend-mvc-plugins": "^1.0.1",
        "zendframework/zend-psr7bridge": "^0.2.2",
        "zendframework/zend-serializer": "^2.8",
        "zendframework/zend-session": "^2.7.1",
        "zendframework/zend-stratigility": "^2.0.1",
        "zfcampus/zf-development-mode": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "AreaRestrita\\": "module/AreaRestrita/src/",
            "AreaRestritaAnuncio\\": "module/AreaRestritaAnuncio/src/",
            "SnBH\\ApiModel\\": "module/ApiModel/src/",
            "SnBH\\Common\\": "module/Common/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApplicationTest\\": "module/Application/test/"
        }
    },
    "repositories": [{
            "type": "vcs",
            "url": "https://bitbucket.org/seminovosbh/api-client-module.git"
        },
        {
            "type": "vcs",
            "url": "https://bitbucket.org/seminovosbh/api-client.git"
        }],
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "development-disable": "zf-development-mode disable",
        "development-enable": "zf-development-mode enable",
        "development-status": "zf-development-mode status",
        "post-create-project-cmd": [
            "@development-enable"
        ],
        "serve": "php -S 0.0.0.0:8080 -t public public/index.php",
        "test": "phpunit"
    },
    "require-dev": {
        "zendframework/zend-developer-tools": "^1.1.0",
        "zendframework/zend-test": "^3.0.1"
    }
}
