{
    "name": "snbh/area-restrita",
    "description": "Skeleton Application for Zend Framework zend-mvc applications",
    "type": "project",
    "license": "BSD-3-Clause",
    "keywords": [
        "framework",
        "mvc",
        "zf"
    ],
    "homepage": "http://framework.zend.com/",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "apcu-autoloader": true,
        "sort-packages": true,
        "vendor-dir": "vendor",
        "optimize-autoloader": true,
        "allow-plugins": {
            "laminas/laminas-dependency-plugin": true
        }
    },
    "require": {
        "php": "^8.2",
        "aws/aws-sdk-php": "^3.263",
        "laminas/laminas-cache-storage-adapter-filesystem": "^2.3",
        "laminas/laminas-cache-storage-adapter-redis": "^2.5",
        "laminas/laminas-cache-storage-deprecated-factory": "^1.1",
        "laminas/laminas-development-mode": "^3.10",
        "laminas/laminas-eventmanager": "^3.10",
        "laminas/laminas-i18n": "^2.22",
        "laminas/laminas-i18n-resources": "^2.9",
        "laminas/laminas-mvc": "^3.6",
        "laminas/laminas-mvc-i18n": "^1.7",
        "laminas/laminas-mvc-middleware": "^2.3",
        "laminas/laminas-mvc-plugins": "^1.2",
        "laminas/laminas-psr7bridge": "^1.9",
        "laminas/laminas-serializer": "^2.14",
        "laminas/laminas-session": "^2.16",
        "laminas/laminas-stratigility": "^3.9",
        "laminas/laminas-zendframework-bridge": "^1.7",
        "snbh/api-client-module": "^2.0",
        "snbh/logger": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "AreaRestritaAnuncio\\": "module/AreaRestritaAnuncio/src/",
            "AreaRestrita\\": "module/AreaRestrita/src/",
            "SnBH\\ApiModel\\": "module/ApiModel/src/",
            "SnBH\\Common\\": "module/Common/src/",
            "SnBH\\Integrador\\": "module/Integrador/src/",
            "SnBH\\GalaxPay\\": "module/GalaxPay/src/",
            "SnBH\\Zoop\\": "module/Zoop/src/",
            "SnBH\\Importer\\": "module/Importer/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApplicationTest\\": "module/Application/test/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://bitbucket.org/seminovosbh/api-client-module.git"
        },
        {
            "type": "vcs",
            "url": "https://bitbucket.org/seminovosbh/api-client.git"
        },
        {
            "type": "vcs",
            "url": "https://bitbucket.org/seminovosbh/logger.git"
        }
    ],
    "scripts": {
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "dev-disable": "laminas-development-mode disable",
        "dev-enable": "laminas-development-mode enable",
        "dev-status": "laminas-development-mode status",
        "static-analysis-report": [
            "php vendor/bin/psalm --output-format=xml > data/cache/psalm-output.xml || exit 0",
            "cat data/cache/psalm-output.xml | docker run --rm -i psalm-html-output:latest > public/psalm-report.html",
            "echo Finish"
        ],
        "test": "phpunit"
    },
    "require-dev": {
        "psalm/plugin-phpunit": "^0.18.4",
        "vimeo/psalm": "^5.15"
    }
}
