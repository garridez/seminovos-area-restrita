<?xml version="1.0"?>
<ruleset name="Zend Framework coding standard">
    <description>Zend Framework coding standard</description>

    <arg value="p"/>
    <arg name="cache" value="data/cache/.phpcs-cache"/>
    <arg name="colors"/>
    <arg name="extensions" value="php,dist,phtml"/>

    <rule ref="LaminasCodingStandard">

        <exclude name="Generic.Formatting.MultipleStatementAlignment.NotSame"/>
        <exclude name="Generic.Files.InlineHTML.Found"/>
        <exclude name="Generic.Formatting.SpaceAfterNot.Incorrect"/>
        <exclude name="SlevomatCodingStandard.Namespaces.ReferenceUsedNamesOnly.ReferenceViaFallbackGlobalName"/>
        <exclude name="SlevomatCodingStandard.Operators.DisallowEqualOperators.DisallowedEqualOperator"/>
        <exclude name="SlevomatCodingStandard.Operators.DisallowEqualOperators.DisallowedNotEqualOperator"/>
        <exclude name="SlevomatCodingStandard.TypeHints.DeclareStrictTypes.DeclareStrictTypesMissing"/>
        <exclude name="WebimpressCodingStandard.Arrays.DoubleArrow.SpacesBefore"/>
        <exclude name="WebimpressCodingStandard.NamingConventions.ValidVariableName.NotCamelCapsProperty"/>
        <exclude name="WebimpressCodingStandard.NamingConventions.ValidVariableName.NotCamelCaps"/>

        <!-- !Corrigir -->
        <exclude name="Generic.PHP.ForbiddenFunctions.Found"/>
        <exclude name="Generic.Files.LineLength.TooLong"/>
        <!-- !Corrigir -->
    </rule>

    <rule ref="WebimpressCodingStandard.Formatting.StringClassReference.Found">
        <exclude-pattern>*config.php</exclude-pattern>
    </rule>
    <rule ref="SlevomatCodingStandard.Commenting.InlineDocCommentDeclaration.MissingVariable">
        <exclude-pattern>*.phtml</exclude-pattern>
    </rule>

    <!-- Paths to check -->
    <file>config</file>
    <file>module</file>
    <file>public/index.php</file>
</ruleset>
