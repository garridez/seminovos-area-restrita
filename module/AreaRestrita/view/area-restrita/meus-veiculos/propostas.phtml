<?php

/** @var \Laminas\View\Renderer\PhpRenderer $this */
$veiculo = $this->veiculo;

/* @var $formatDate \AreaRestrita\View\Helper\Data */
$formatDate = new \AreaRestrita\View\Helper\Data();

$temPropostas = count($this->propostas) > 0;
?>
<div class="ds-propostas">

    <header class="ds-propostas__head">
        <h3>Propostas recebidas por e-mail</h3>
        <p>Essas mensagens foram recebidas no seu e-mail &mdash; responda por lá.</p>
    </header>

    <div class="ds-timeline">

        <!-- Âncora: o veículo -->
        <article class="ds-timeline__item ds-timeline__item--anchor">

            <div class="ds-timeline__card ds-veiculo-card">
                <div class="ds-veiculo-card__foto">
                    <img src="<?= $veiculo['imagem'] ?>"
                         alt="<?= $this->escapeHtmlAttr($veiculo['marca'] . ' ' . $veiculo['modelo']) ?>">
                </div>
                <div class="ds-veiculo-card__info">
                    <h4>
                        <?= $veiculo['marca'] . ' ' . $veiculo['modelo'] ?>
                        <small><?= $veiculo['motor'] . ' ' . $veiculo['valvula'] ?>V</small>
                    </h4>
                    <ul class="ds-data-list">
                        <li><span>Placa</span><strong><?= strtoupper((string) $veiculo['placa']) ?></strong></li>
                        <li><span>Valor</span><strong>R$ <?= $veiculo['valorFormatado'] ?></strong></li>
                        <li><span>Quilometragem</span><strong><?= $veiculo['kilometragemFormatada'] ?> km</strong></li>
                        <li><span>Código</span><strong><?= $veiculo['idVeiculo'] ?></strong></li>
                    </ul>
                </div>
            </div>

            <div class="ds-timeline__marker ds-timeline__marker--anchor">
                <i class="fa fa-car"></i>
            </div>

            <div class="ds-timeline__date">
                <span class="ds-timeline__date-label">Cadastrado em</span>
                <span class="ds-timeline__date-value"><?= $formatDate->dataPorExtenso($veiculo['dataCadastro']) ?></span>
            </div>
        </article>

        <?php if ($temPropostas) : ?>
            <?php foreach ($this->propostas as $proposta) : ?>
                <article class="ds-timeline__item">

                    <div class="ds-timeline__card ds-proposta-card">
                        <h5><?= $proposta['nome'] ?></h5>
                        <ul class="ds-proposta-card__contato">
                            <li>
                                <i class="fa fa-envelope"></i>
                                <a href="mailto:<?= $this->escapeHtmlAttr($proposta['email']) ?>"><?= strtolower((string) $proposta['email']) ?></a>
                            </li>
                            <li>
                                <i class="fa fa-phone"></i>
                                <a href="tel:<?= preg_replace('/\D/', '', (string) $proposta['telefone']) ?>"><?= $proposta['telefone'] ?></a>
                            </li>
                        </ul>
                        <div class="ds-proposta-card__msg">
                            <span class="ds-proposta-card__msg-label">Mensagem</span>
                            <p><?= $proposta['texto'] ?></p>
                        </div>
                    </div>

                    <div class="ds-timeline__marker"></div>

                    <div class="ds-timeline__date">
                        <span class="ds-timeline__date-value"><?= $formatDate->dataPorExtenso($proposta['data']) ?></span>
                    </div>
                </article>
            <?php endforeach; ?>
        <?php else : ?>
            <article class="ds-timeline__item ds-timeline__item--empty">

                <div class="ds-timeline__card ds-proposta-card ds-proposta-card--empty">
                    <i class="fa fa-inbox"></i>
                    <h5>Nenhuma proposta recebida</h5>
                    <p>Este veículo ainda não recebeu propostas por e-mail.</p>
                </div>

                <div class="ds-timeline__marker"></div>

                <div class="ds-timeline__date">
                    <span class="ds-timeline__date-value"><?= $formatDate->dataPorExtenso(date('Y-m-d')) ?></span>
                </div>
            </article>
        <?php endif; ?>

    </div>
</div>
