<!-- Modal lembrar senha revenda -->
<div class="modal fade" id="modalLembrarSenhaRevenda" tabindex="-1" role="dialog" aria-labelledby="modalLembrarSenhaLabelRevenda"
     aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title text-warning" id="modalLembrarSenhaLabel">Esqueci minha senha</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Fechar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="container">
                    <div class="row py-2">
                        <div class="col-md-12 no-padding sm-p-l-10">
                            <p class="text-justify">
                                Entre em contato com nosso atendimento para recuperar sua senha de acesso.<br>
                                Lembre-se de ter os dados da sua revenda em mãos.<br>
                                Telefone do nosso atendimento: <a href="tel:+553130775888">(31) 3077-5888</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function solicitarToken() {
        var telefone = document.getElementById('lembrarSenhaTelefone').value;
        telefone = telefone.replace(/\D/g, '');

        if (telefone == '') {
            alert('Preencha o telefone');
            return false;
        }

        let formData = new FormData();
        formData.append("telefone", telefone);

        fetch('/remember-pass-phone', {
                method: 'POST',
                body: formData
            })
            .then((response) => {
                return response.json();
            
            })
            .then((response) => {
                if (response.status == 201) {
                    mudarPasso('passo2');
                } else {
                    document.getElementById('telefone_invalido').style.display = 'block';
                }
            })
            .catch(function (error) {
                console.log("Error: " + error);
            });
    }

    function validarToken() {
        var token = document.getElementById('token').value;
        let formData = new FormData();
        formData.append("token", token);

        fetch('/validate-token', {
                method: 'POST',
                body: formData
            })
            .then((response) => {
                return response.json();
            
            })
            .then((response) => {
                if (response.data.token == token) {
                    document.getElementById('idCadastro').value = response.data.idCadastro;
                    mudarPasso('passo3');
                } else {
                    document.getElementById('token_invalido').style.display = 'block';
                }
            })
            .catch(function (error) {
                console.log("Error: " + error);
            });
    }


    function salvarNovaSenha() {
        var senha = document.getElementById('senha').value;
        var confirmacao_senha = document.getElementById('confirmacao_senha').value;
        var idCadastro = document.getElementById('idCadastro').value;

        if (senha != '' && senha != confirmacao_senha) {
            alert('senhas não coincidem');
            return false;
        }

        if (senha.length < 4) {
            alert('A senha deve conter no mínimo 4 caracteres.');
            return false;
        }

        let formData = new FormData();
        formData.append("senha", senha);
        formData.append("idCadastro", idCadastro);

        fetch('/remember-pass-save', {
                method: 'POST',
                body: formData
            })
            .then((response) => {
                return response.json();
            
            })
            .then((response) => {
                if(response.status == 200) {
                    mudarPasso('passo4');
                }
            })
            .catch(function (error) {
                console.log("Error: " + error);
            });
    }

    function mudarPasso(passoAtual) {
        for (let i = 1; i <= 4; i++) {
            let passoTemp = 'passo' + i;

            if(passoAtual == passoTemp) {
                document.getElementById(passoAtual).style.display = 'block';
                document.getElementById('footer_' + passoAtual).style.display = 'block';
            } else {
                document.getElementById(passoTemp).style.display = 'none';
                document.getElementById('footer_' + passoTemp).style.display = 'none';
            }
        } 
    }

    function mascaraTelefone(telefone) {
        telefone = telefone.replace(/\D/g, '');
        telefone = telefone.replace(/(\d{1,2})?(\d{1})?(\d{1,4})?(\d{4})?/, '($1) $2 $3-$4');
        document.getElementById('lembrarSenhaTelefone').value = telefone;
    }

    function fecharModal(modal) {
        $('#' + modal).modal('hide');
    }
</script>


