<!-- Modal lembrar senha email/cpf -->
<div class="modal fade" id="modalLembrarSenha" tabindex="-1" role="dialog" aria-labelledby="modalLembrarSenhaLabel"
     aria-hidden="true">
    <form method="POST" name="formLembrarSenha" id="formLembrarSenha" action="remember-pass">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h5 class="modal-title text-warning" id="modalLembrarSenhaLabel">Esqueci minha senha</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Fechar">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="container">
                        <div class="row pt-2">
                            <div class="col-md-12 no-padding sm-p-l-10">
                                <p>Não lembra sua senha? Digite o e-mail ou CPF cadastrado do portal no campo abaixo, para
                                    receber sua nova senha!</p>
                            </div>
                        </div>
                        <div class="row pb-2">
                            <div class="form-group col-12">
                                <div class="col-md-12 no-padding sm-p-l-10">
                                    <div class="input-group">
                                        <input type="text" id="emailLembrarSenha" name="emailLembrarSenha" class="form-control" id="inlineFormInputGroup" placeholder="Email ou CPF">
                                    </div>
                                    <p class="text-justify mt-2"> 
                                        Não lembro ou não possuo meu e-mail e CPF. <br>
                                        <a href="#" data-toggle="modal" onclick="fecharModal('modalLembrarSenha')" data-target="#modalLembrarSenhaTelefone" class="text-info btn-esqueci-minha-senha semi-bold">
                                            <span class="semi-bold"></span>
                                            Recuperar via telefone
                                        </a>
                                    </p>


                                </div>
                            </div>
                        </div>
                        <div class="row border-top py-2">
                            <div class="col-md-12 no-padding sm-p-l-10">
                                <p class="text-justify">Ao solicitar uma nova senha o site enviará a nova senha para
                                    o e-mail cadastrado, se não receber o e-mail na sua caixa de entrada verifique
                                    na sua caixa de lixo eletrônico (spam).</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Enviar</button>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Modal recuperar senha via telefone -->
<div class="modal fade" id="modalLembrarSenhaTelefone" tabindex="-1" role="dialog" aria-labelledby="modalLembrarSenhaTelefoneLabel"
     aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h5 class="modal-title text-warning" id="modalLembrarSenhaTelefoneLabel">Esqueci minha senha</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Fechar">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <!-- Passo 1 - solicitar e enviar o token por sms ao usuario -->
                <div class="modal-body" id="passo1">
                    <div class="container">
                        <div class="row pt-2">
                            <div class="col-md-12 no-padding sm-p-l-10">
                                <p>Insira seu telefone:</p>
                            </div>
                        </div>
                        <div class="row pb-2">
                            <div class="form-group col-12">
                                <div class="col-md-12 no-padding sm-p-l-10">
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <div class="input-group-text">+55</div>
                                        </div>
                                        <input type="text" 
                                            id="lembrarSenhaTelefone" 
                                            name="lembrarSenhaTelefone" 
                                            class="form-control" 
                                            placeholder="Telefone" 
                                            onkeyup="mascaraTelefone(this.value)"
                                            maxlength="16">
                                        </div>
                                        <p class="text-muted small mt-2 text-danger" id="telefone_invalido" style="display:none;">Não foi encontrado um cadastro com esse número de telefone!</p>
                                </div>
                            </div>
                        </div>
                        <div class="row border-top py-2">
                            <div class="col-md-12 no-padding sm-p-l-10">
                                <p class="text-justify">Ao solicitar um token o site enviará um código para o telefone
                                    cadastrado. O código pode demorar ate 1 hora para ser enviado, mas geralmente é na mesma hora.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Passo 2 - Validar token -->
                <div class="modal-body" id="passo2" style="display:none">
                    <div class="container">
                        <div class="row pt-2">
                            <div class="col-md-12 no-padding sm-p-l-10">
                                <p>Insira o código de 4 digitos:</p>
                            </div>
                        </div>
                        <div class="row pb-2">
                            <div class="form-group col-12">
                                <div class="col-md-12 no-padding sm-p-l-10">
                                    <div class="input-group">
                                        <input type="text" 
                                            id="token" 
                                            name="token" 
                                            class="form-control" 
                                            placeholder="X X X X" 
                                            maxlength="4">
                                        </div>
                                    <p class="text-muted small mt-2 text-danger" id="token_invalido" style="display:none;">Código inválido!</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Passo 3 - Nova Senha -->
                <div class="modal-body" id="passo3" style="display:none">
                    <div class="container">
                        <div class="row pt-2">
                            <div class="col-md-12 no-padding sm-p-l-10">
                                <p>Digite uma nova senha. Sua senha deve conter pelo menos 4 caracteres.</p>
                            </div>
                        </div>
                        <div class="row pb-2">
                            <div class="form-group col-12">
                                <div class="col-md-12 no-padding sm-p-l-10">
                                        <input type="hidden" 
                                            id="idCadastro" 
                                            name="idCadastro" 
                                            value=""
                                            >
                                        <input type="text" 
                                            id="senha" 
                                            name="senha" 
                                            class="form-control row col-12" 
                                            placeholder="Nova Senha" 
                                            >

                                        <input type="text" 
                                            id="confirmacao_senha" 
                                            name="confirmacao_senha" 
                                            class="form-control row col-12 mt-4" 
                                            placeholder="Repetir senha" 
                                            >
                                        </div>
                                    <p class="text-muted small mt-2 text-danger" style="display:none;">senha inválida!</p>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Passo 4 - Conclusão -->
                <div class="modal-body" id="passo4" style="display:none">
                    <div class="container">
                        <div class="row pt-2">
                            <div class="col-md-12 no-padding sm-p-l-10">
                                <p>Sua senha foi alterada com sucesso!</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer" id="footer_passo1">
                    <button type="button" class="btn-warning btn" onclick="mudarPasso('passo2')">Ja tenho um código</button>
                    <button type="button" class="btn btn-success" onclick="solicitarToken()">Solicitar código</button>
                </div>
                <div class="modal-footer" id="footer_passo2" style="display:none;">
                    <button type="button" class="btn-warning btn" onclick="mudarPasso('passo1')">Voltar</button>
                    <button type="button" class="btn btn-success" onclick="validarToken()">Enviar</button>
                </div>
                <div class="modal-footer" id="footer_passo3" style="display:none;">
                    <button type="button" class="btn-warning btn" onclick="mudarPasso('passo2')">Voltar</button>
                    <button type="button" class="btn btn-success" onclick="salvarNovaSenha()">Salvar nova senha</button>
                </div>
                <div class="modal-footer" id="footer_passo4" style="display:none;">
                    <button type="button" class="btn btn-success float-right" data-dismiss="modal" aria-label="Fechar">
                        <span aria-hidden="true">Fazer login</span>
                    </button>
                </div>
            </div>
        </div>
</div>

