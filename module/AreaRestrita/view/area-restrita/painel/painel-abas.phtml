                                    echo $diffValues['anos'] . ' ' . ($diffValues['anos'] > 1 ? ' anos' : ' ano') . ', ';
                                }
                                if ($diffValues['meses']) {
                                    echo $diffValues['meses'] . ($diffValues['meses'] > 1 ? ' meses' : ' mês') . ' e ';
