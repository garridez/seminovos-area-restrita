<script>
    (function () {
        // Troca de abas — independente do plugin de tabs do Bootstrap.
        var tabs = document.querySelectorAll('#painel-tabs .nav-link');

        function reflowCharts() {
            if (window.Highcharts && Highcharts.charts) {
                Highcharts.charts.forEach(function (c) {
                    if (c) { c.reflow(); }
                });
            }
        }

        function activate(link) {
            var target = document.querySelector(link.getAttribute('href'));

            tabs.forEach(function (t) {
                t.classList.remove('active');
                t.setAttribute('aria-selected', 'false');
            });
            document.querySelectorAll('.ds-tabs-panel .tab-pane').forEach(function (p) {
                p.classList.remove('show', 'active');
            });

            link.classList.add('active');
            link.setAttribute('aria-selected', 'true');
            if (target) {
                target.classList.add('show', 'active');
            }
            // Highcharts dentro de aba oculta nasce com largura 0 — refluir ao exibir.
            reflowCharts();
        }

        tabs.forEach(function (link) {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                activate(link);
            });
        });
    })();
</script>
