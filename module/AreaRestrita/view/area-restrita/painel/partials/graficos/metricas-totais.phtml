<?php

use AreaRestrita\View\Helper\AutocompleteClass;

/** @var AutocompleteClass $this */
/** @var array  $metricasPorData */
/** @var string $metrica  'acesso' | 'telefone' | 'impressao' */

$titulos = [
    'acesso'    => 'Cliques em veículos',
    'telefone'  => 'Cliques em ver telefone',
    'impressao' => 'Veículos impressos no resultado de busca',
];
$titulo = $titulos[$metrica] ?? ucfirst((string) $metrica);

$dateHelper = $this->dateHelper();

$data = [];
if (!empty($metricasPorData[$metrica])) {
    ksort($metricasPorData[$metrica]);
    foreach ($metricasPorData[$metrica] as $date => $value) {
        $data[] = [
            'x' => $dateHelper->dateToJsTimestamp($date),
            'y' => $value,
        ];
    }
}

?>
<div class="container-chart" id="chart-metrica-<?= $metrica ?>"></div>
<script>
    (function () {
        Highcharts.chart(document.getElementById('chart-metrica-<?= $metrica ?>'), {
            chart: { type: 'area' },
            title: { text: '<?= $titulo ?>' },
            subtitle: { text: 'No último mês na seminovos.com.br' },
            xAxis: { type: 'datetime' },
            yAxis: { title: { text: 'Quantidade' }, allowDecimals: false },
            legend: { enabled: false },
            credits: { enabled: false },
            tooltip: { crosshairs: true, shared: true },
            plotOptions: {
                area: {
                    marker: { enabled: false },
                    fillOpacity: 0.15,
                },
                series: { animation: false },
            },
            series: [{
                name: '<?= $titulo ?>',
                color: '#db9524',
                data: <?= json_encode($data) ?>,
            }],
        });
    })();
</script>
