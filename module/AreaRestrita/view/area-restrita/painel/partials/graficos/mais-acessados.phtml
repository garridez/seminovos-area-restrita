<?php

use AreaRestrita\View\Helper\AutocompleteClass;

/** @var AutocompleteClass $this */
/** @var array $maisAcessados */

$dateHelper = $this->dateHelper();

$renderChart = function ($data, $key, $title) use ($dateHelper) {
    $series = [];

    foreach ($data as $date => $rows) {
        foreach ($rows as $id => $row) {
            $name = $row[$key];
            $series[$name] ??= [
                'name' => $name,
                'data' => [],
            ];
            $series[$name]['data'][] = [
                'x' => $dateHelper->dateToJsTimestamp($date),
                'y' => $row['qtd'],
            ];
        }
    }
    foreach ($series as $kSerie => $serie) {
        usort($serie['data'], function ($a, $b) {
            return $a['x'] <=> $b['x'];
        });
        $series[$kSerie]['data'] = $serie['data'];
    }
    ?>
    <div class="container-chart" id="chart-buscados-<?= $key ?>"></div>
    <script>
        (function () {
            var series = <?= json_encode(array_values($series)); ?>;
            Highcharts.chart(document.getElementById('chart-buscados-<?= $key ?>'), {
                chart: { type: 'line' },
                title: { text: '<?= $title ?>' },
                subtitle: { text: 'No último mês na seminovos.com.br' },
                xAxis: { type: 'datetime' },
                yAxis: [{ title: { text: 'Quantidade de buscas' } }],
                credits: { enabled: false },
                tooltip: { crosshairs: true, shared: true },
                plotOptions: {
                    line: { marker: { enabled: false } },
                    series: { animation: false },
                },
                series: series,
            });
        })();
    </script>
    <?php
};

// modelos em cima, marcas embaixo — sem sub-abas
$renderChart($maisAcessados['modelo'], 'modelo', 'Modelos mais buscados');
$renderChart($maisAcessados['marca'], 'marca', 'Marcas mais buscadas');
