<?php
/** @var \AreaRestrita\View\Helper\AutocompleteClass $this */
use \SnBH\Common\Helper\StringFuncs;

// Ícone FontAwesome de cada plano. Para trocar, é só editar aqui.
$iconesPlano = [
    'nitro' => 'fa-bolt',
    'turbo' => 'fa-rocket',
    'flex'  => 'fa-car',
];
$iconePadrao = 'fa-tag';

if ($this->userInfo('tipoCadastro') == 1) {
    $arrayPlanos = [
        1 => ['nitro', 'Nitro', '15', 'alta', '', '', 'nitro-value', $this->qtdAnuncios()->totalNitro, $this->qtdAnuncios()->totalNitroPublicados],
        2 => ['turbo', 'Turbo', '09', 'média', '', '', 'turbo-value', $this->qtdAnuncios()->totalTurbo, $this->qtdAnuncios()->totalTurboPublicados],
        3 => ['flex', 'Flex',   '06', 'baixa', '', '', 'flex-value', $this->qtdAnuncios()->totalBasico, $this->qtdAnuncios()->totalBasicoPublicado],
    ];
    foreach ($arrayPlanos as $i => $plano):
        [$slug, $plano, $fotos, $nivel, $video, $preco, $classValue, $totalAnuncio, $totalAnuncioPublicado] = $plano;
        $icone = $iconesPlano[$slug] ?? $iconePadrao;

        ?>
        <div class="qtd-plano d-flex align-items-center bg-color-menu-dark my-1 p-2 plano-<?= $slug ?>">
            <span class="qtd-plano-icone">
                <i class="fa <?= $icone ?>" aria-hidden="true"></i>
            </span>
            <div class="text-left ml-2 title">
                <div>
                    <b><?= $plano ?></b> <?php echo $totalAnuncioPublicado . "/" . $totalAnuncio ?>
                </div>
            </div>
        </div>
        <?php
    endforeach;
} elseif ($this->userInfo('tipoCadastro') == 2) {
    $planos = $this->planos();
    usort($planos, function($a, $b) {
        return $a['ordem'] <=> $b['ordem'];
    });
    $planosUsados = $this->planosUsados();
    foreach ($planos as $i => $plano):
        $slug = preg_replace('/[^a-zA-Z ]/', '', StringFuncs::removerAcentos($plano['nomePlano']));
        $slug = preg_replace('/ +/', '-', $slug);
        $usados = $planosUsados[$plano['idPlano']] ?? [
            'publicado' => 0,
            'total' => 0
        ];
        $icone = $iconesPlano[strtolower($slug)] ?? $iconePadrao;

        ?>
        <div class="qtd-plano d-flex align-items-center bg-color-menu-dark my-1 p-2 plano-<?= $slug ?>" title="<?php echo  "{$usados['publicado']} ativo(s) / {$usados['total']} cadastrado(s)"  ?>">
            <span class="qtd-plano-icone">
                <i class="fa <?= $icone ?>" aria-hidden="true"></i>
            </span>
            <div class="text-left ml-2 title">
                <div>
                    <b><?= $plano['nomePlano'] ?></b>
                    <?php echo $usados['publicado'] . "/" . $usados['total'] ?>
                </div>
            </div>
        </div>
        <?php
    endforeach;
}
