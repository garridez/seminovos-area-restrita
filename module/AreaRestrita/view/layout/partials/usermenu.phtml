<?php

/** @var \AreaRestrita\View\Helper\AutocompleteClass $this */

// --- Identidade do usuário ---------------------------------------
$dsTipo = $this->userInfo('tipoCadastro');
if ($dsTipo == 1) {
    $dsNomeCompleto = (string) $this->userInfo('nomeFantasia');
    $dsTipoLabel    = 'Revenda';
} elseif ($dsTipo == 2) {
    $dsNomeCompleto = (string) $this->userInfo('responsavelNome');
    $dsTipoLabel    = 'Particular';
} else {
    $dsNomeCompleto = '';
    $dsTipoLabel    = '';
}

$dsNomeCompleto = trim($dsNomeCompleto);
if ($dsNomeCompleto === '') {
    $dsNomeCompleto = 'Não informado';
}

// iniciais: primeira letra do primeiro e do último nome
$dsPartes   = preg_split('/\s+/', $dsNomeCompleto);
$dsIniciais = mb_strtoupper(mb_substr($dsPartes[0], 0, 1));
if (count($dsPartes) > 1) {
    $dsIniciais .= mb_strtoupper(mb_substr(end($dsPartes), 0, 1));
}
$dsNomeCurto = $dsPartes[0] . (isset($dsPartes[1]) ? ' ' . $dsPartes[1] : '');

global $container;
$dsUrlSite  = $container->get('Config')['SnBH']['urls']['site'] ?? '/';
$dsWhatsapp = $dsTipo == 1 ? '5531995502814' : '5531996071787';
?>
